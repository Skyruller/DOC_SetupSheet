<UserControl x:Class="SetupSheet.ToolSheetPaneWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SetupSheet"
             mc:Ignorable="d" 
             Height="Auto"
             MinHeight="350"
             Width="350"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="140"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Секция NC Программы -->
            <GroupBox Grid.Row="0" Header="NC Программы" Margin="0,0,0,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левый список -->
                    <ListBox x:Name="listNCProgs" Grid.Column="0" Margin="2" SelectionMode="Extended"
                             AllowDrop="True" DragOver="listNCProgs_DragOver" Drop="listNCProgs_Drop"
                             PreviewMouseMove="listNCProgs_PreviewMouseMove"/>

                    <!-- Кнопки переноса -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0">
                        <Button x:Name="AddNCProg" Content="▶" Width="25" Height="25" Margin="0,5" 
                                Click="AddNCProg_Click" FontWeight="Bold"/>
                        <Button x:Name="RemoveNCProg" Content="◀" Width="25" Height="25" Margin="0,5" 
                                Click="RemoveNCProg_Click" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Кнопки изменения порядка -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="2,0">
                        <Button x:Name="MoveUpBtn" Content="⬆" Width="25" Height="25" Margin="0,5" 
                                Click="MoveUpBtn_Click" FontWeight="Bold" ToolTip="Поднять выше"/>
                        <Button x:Name="MoveDownBtn" Content="⬇" Width="25" Height="25" Margin="0,5" 
                                Click="MoveDownBtn_Click" FontWeight="Bold" ToolTip="Опустить ниже"/>
                    </StackPanel>

                    <!-- Правый список -->
                    <ListBox x:Name="listNCProgsSelected" Grid.Column="3" Margin="2" SelectionMode="Extended"
                             AllowDrop="True" DragOver="listNCProgsSelected_DragOver" Drop="listNCProgsSelected_Drop"
                             PreviewMouseMove="listNCProgsSelected_PreviewMouseMove"/>
                </Grid>
            </GroupBox>

            <!-- Секция Настройки -->
            <GroupBox Grid.Row="1" Header="Настройки" Margin="0,3,0,3">
                <Grid Margin="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" VerticalAlignment="Center" Margin="0,0,5,3"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,3">
                        <RadioButton x:Name="OneSideRadio" Content="1-стор" GroupName="SideType" IsChecked="True" Margin="0,0,10,0"/>
                        <RadioButton x:Name="TwoSideRadio" Content="2-стор" GroupName="SideType"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Станок:" VerticalAlignment="Center" Margin="0,0,5,3"/>
                    <ComboBox x:Name="MachineComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,3" SelectionChanged="MachineComboBox_SelectionChanged">
                        <ComboBoxItem Content="Siemens, Fanuc (переворот X)" Tag="X"/>
                        <ComboBoxItem Content="Beaver, Osai, Syntec (переворот Y)" Tag="Y"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Позиц:" VerticalAlignment="Center" Margin="0,0,5,3"/>
                    <TextBox x:Name="PositionHolesTextBox" Grid.Row="2" Grid.Column="1" Width="80" Height="20" Text="X0Y0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Материал:" VerticalAlignment="Center" Margin="0,0,5,3"/>
                    <TextBox x:Name="MaterialTextBox" Grid.Row="3" Grid.Column="1" Width="150" Height="20" Text="Д16Т"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Артикул:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="ArticleTextBox" Grid.Row="4" Grid.Column="1" Width="150" Height="20" Text=""/>
                </Grid>
            </GroupBox>

            <!-- Секция Скриншот -->
            <GroupBox Grid.Row="2" Header="Скриншот" Margin="0,3,0,3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="2" Background="#F0F0F0">
                        <Image x:Name="Setup_Picture" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="2">
                        <Button x:Name="Get_Picture" Content="📷 Скрин" Width="80" Height="22" Margin="2,0" Click="Get_Picture_Click"/>
                        <Button x:Name="Del_Picture" Content="🗑" Width="50" Height="22" Margin="2,0" Click="Del_Picture_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Кнопка Generate -->
            <Button x:Name="Generate" Grid.Row="3" Content="✨ Сгенерировать" Height="30" Margin="0,3" Click="Generate_Click" FontWeight="Bold" Background="#E8F4FD"/>

            <!-- Комментарии -->
            <GroupBox Grid.Row="4" Header="Комментарии" Margin="0,3,0,3">
                <TextBox x:Name="Comments_TextBox" Height="55" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="2"/>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>